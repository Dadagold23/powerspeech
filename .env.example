# =============================================================
#  AI Speech Notes — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# =============================================================

# ── Speech-to-Text (Whisper) ──────────────────────────────────
# Model size controls accuracy vs. speed trade-off.
# Smaller models load faster and use less RAM.
# Options: tiny | base | small | medium | large
# Recommended for development : base
# Recommended for production  : small or medium
WHISPER_MODEL=base

# Microphone / audio file sample rate in Hz.
# Whisper expects 16000 Hz — change only if you know what you are doing.
AUDIO_SAMPLE_RATE=16000

# ── Summarization (Hugging Face / BART) ──────────────────────
# Hugging Face model ID for the summarization pipeline.
# Default is facebook/bart-large-cnn (abstractive, English-focused).
# Multilingual alternative: facebook/mbart-large-cc25
SUMMARIZATION_MODEL=facebook/bart-large-cnn

# Maximum number of tokens in the generated summary.
SUMMARY_MAX_LENGTH=150

# Minimum number of tokens in the generated summary.
SUMMARY_MIN_LENGTH=40

# ── Storage ───────────────────────────────────────────────────
# Directories where transcripts and summaries are saved.
# Paths are relative to the project root.
TRANSCRIPTS_DIR=data/transcripts
SUMMARIES_DIR=data/summaries

# ── User Interface ────────────────────────────────────────────
# Initial colour theme for the GUI.
# Can also be changed live inside the application.
# Options: dark | light
UI_THEME=dark

# ── Logging ───────────────────────────────────────────────────
# Controls verbosity of log output and the app.log file.
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
